<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#D32F2F"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvAvatarProfile"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_circle_avatar"
            android:gravity="center"
            android:text="H"
            android:textColor="#D32F2F"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvAvatarProfile"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="12dp"
            android:text="CÀ HOÀNG HUY"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDanhHieu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvProfileName"
            android:layout_centerHorizontal="true"
            android:text="Người gieo hy vọng"
            android:textColor="#FFCDD2"
            android:textSize="14sp" />
    </RelativeLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStatsDonor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="-40dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="8dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvProfileNhomMau"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="O+"
                    android:textColor="#D32F2F"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhóm máu"
                    android:textSize="12sp" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvSoLanHien"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="05"
                    android:textColor="#D32F2F"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lần hiến"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStatsMedical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="-40dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="8dp"
        android:visibility="gone"> <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvMaSoThue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MST: 0101234567"
            android:textColor="#D32F2F"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã số thuế cơ sở y tế"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvNgayHienGanNhat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_edittext"
            android:padding="15dp"
            android:text="Ngày hiến gần nhất: 12/04/2026"
            android:drawableStart="@android:drawable/ic_menu_my_calendar"
            android:drawablePadding="10dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnVerifyBlood"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:text="XÁC MINH NHÓM MÁU"
            android:backgroundTint="#FFFFFF"
            android:textColor="#212121"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="CHỈNH SỬA THÔNG TIN"
            android:backgroundTint="#FFFFFF"
            android:textColor="#212121"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"/>

        <Button
            android:id="@+id/btnLichSuHienMau"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:text="LỊCH SỬ HIẾN MÁU"
            android:backgroundTint="#FFFFFF"
            android:textColor="#212121"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:text="ĐĂNG XUẤT"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="#D32F2F"/>
    </LinearLayout>
</LinearLayout>