<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarCheckIn"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#D32F2F"
        app:title="Thông tin tham gia"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="300dp"
                android:layout_height="300dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/imgQrCheckIn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp"
                    android:src="@drawable/qr_code_scanner_48" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Đưa mã này cho y tá tại bàn tiếp đón"
                android:textColor="#757575"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvMaDinhDanh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HM-XXXXXX"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginTop="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTenSuKien"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên bệnh viện tổ chức"
                        android:textColor="#D32F2F"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDiaChiSuKien"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Địa chỉ: 123 Đường ABC, Quận X, TP. Y"
                        android:textColor="#424242" />

                    <Button
                        android:id="@+id/btnMoBanDo"
                        style="@style/Widget.MaterialComponents.Button.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#1976D2"
                        android:text="DẪN ĐƯỜNG ĐẾN SỰ KIỆN"
                        app:icon="@drawable/map_48" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>