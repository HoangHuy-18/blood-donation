<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạo yêu cầu hiến máu"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="5dp" />

        <!-- Phần chọn Loại tin (Sẽ ẩn nếu là cá nhân) -->
        <LinearLayout
            android:id="@+id/layoutLoaiTin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLabelLoaiTin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại tin đăng"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleLoaiTin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true"
                app:checkedButton="@+id/btnTinKhanCap">

                <Button
                    android:id="@+id/btnTinKhanCap"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Đăng tin" />

                <Button
                    android:id="@+id/btnSuKien"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sự kiện" />

                <Button
                    android:id="@+id/btnLienVien"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Liên viện" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutEventDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên sự kiện vận động"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEventName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngày diễn ra sự kiện"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <Button
                    android:id="@+id/btnPickStartDate"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Từ ngày"
                    android:layout_marginEnd="4dp"/>
                <Button
                    android:id="@+id/btnPickEndDate"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Đến ngày"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khung giờ tiếp nhận hằng ngày"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/btnPickStartTime"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Giờ mở"
                    android:layout_marginEnd="4dp"/>
                <Button
                    android:id="@+id/btnPickEndTime"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Giờ đóng"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Địa điểm tiếp nhận"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickHospitalLocation"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="CHỌN VỊ TRÍ TRÊN BẢN ĐỒ"
                    app:icon="@android:drawable/ic_dialog_map"
                    app:strokeColor="#000000"
                    android:textColor="#D32F2F"
                    app:iconTint="#000000"/>

                <TextView
                    android:id="@+id/tvSelectedHospitalName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Địa chỉ: Chưa chọn"
                    android:textColor="#757575"
                    android:layout_marginTop="12dp"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chi tiết máu đã chọn"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBloodSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chưa có thông tin nhóm máu"
                    android:textColor="#757575"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvBloodHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="* Đối với Sự kiện, bạn có thể không cần chọn nhóm máu cụ thể."
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:textColor="#D32F2F"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddBloodGroup"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ THÊM NHÓM MÁU"
                    android:textColor="#D32F2F"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSoNguoiCan"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Số người cần hiến">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSoNguoiCan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nội dung/Lý do chi tiết">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="top"
                android:inputType="textMultiLine" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnPostRequest"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="ĐĂNG TIN CẤP CỨU"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:elevation="4dp" />

    </LinearLayout>
</ScrollView>