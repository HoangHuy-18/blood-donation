        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HienMau">

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyCi_aaePnEGEJ6p9Ecui47mv0Feb8w9k3U" />

        <uses-library android:name="org.apache.http.legacy" android:required="false" />

        <activity android:name=".MainActivity"/>
        <activity android:name=".ForgotPasswordActivity"/>
        <activity android:name=".MapsPickerActivity"/>
        <activity android:name=".RegisterMedicalActivity"/>
        <activity android:name=".RegisterMedicalImagesActivity"/>
        <activity android:name=".RegisterPersonalActivity"/>
        <activity android:name=".RegisterTypeActivity"/>
        <activity android:name=".ChiTietYeuCauActivity"/>
        <activity android:name=".DanhSachTinhNguyenActivity"/>
        <activity android:name=".TrackingMapActivity"/>
        <activity android:name=".CheckInEventActivity"/>
