@page
@model QuanLyHienMauApi.Pages.Admin.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Trang chủ";
}

<div class="welcome-box shadow-sm">
    <h2 class="fw-bold">Xin chào, Quản trị viên!</h2>
    <p class="mb-0">Chào mừng bạn quay trở lại hệ thống hiến máu.</p>
</div>

<div class="row">
    <div class="col-md-4">
        <a href="/Admin/DuyetCoSo" class="text-decoration-none">
            <div class="card p-4 shadow-sm border-0 transition-hover" style="border-radius: 15px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="text-danger fw-bold mb-0">@Model.CountChoDuyet</h1>
                        <p class="text-muted mb-0">Cơ sở chờ duyệt</p>
                    </div>
                    <div class="bg-light-danger p-3 rounded-circle">
                        <i class="fa-solid fa-hospital-user text-danger fs-3"></i>
                    </div>
                </div>
                <div class="mt-3 small text-primary">
                    Click để phê duyệt ngay <i class="fa-solid fa-chevron-right ms-1"></i>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="/Admin/DuyetNhomMau" class="text-decoration-none">
            <div class="card p-4 shadow-sm border-0 transition-hover" style="border-radius: 15px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="text-primary fw-bold mb-0">@Model.CountXacMinhMau</h1>
                        <p class="text-muted mb-0">Xác minh nhóm máu</p>
                    </div>
                    <div class="bg-light-primary p-3 rounded-circle">
                        <i class="fa-solid fa-droplet text-primary fs-3"></i>
                    </div>
                </div>
                <div class="mt-3 small text-primary">
                    Xem danh sách chờ <i class="fa-solid fa-chevron-right ms-1"></i>
                </div>
            </div>
        </a>
    </div>
</div>
