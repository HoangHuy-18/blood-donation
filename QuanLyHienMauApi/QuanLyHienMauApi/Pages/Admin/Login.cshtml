@page
@model QuanLyHienMauApi.Pages.Admin.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Login - Hệ thống Hiến Máu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
            body { background: #f8f9fa; display: flex; align-items: center; height: 100vh; }
            .login-card { width: 100%; max-width: 400px; padding: 30px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); background: white; }
            .btn-blood { background-color: #d32f2f; color: white; }
            .btn-blood:hover { background-color: #b71c1c; color: white; }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center">
        <div class="login-card">
            <div class="text-center mb-4">
                <h3 class="text-danger fw-bold">ADMIN LOGIN</h3>
                <p class="text-muted">Quản lý hệ thống kết nối hiến máu</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert alert-danger p-2 small">@Model.Message</div>
            }

            <form method="post">
                @Html.AntiForgeryToken() <div class="mb-3">
                    <label class="form-label">Số điện thoại</label>
                    <input type="text" asp-for="SDT" class="form-control" placeholder="Nhập SDT" required>
                </div>      
                <div class="mb-3">
                    <label class="form-label">Mật khẩu</label>
                    <input type="password" asp-for="MatKhau" class="form-control" placeholder="******" required>
                </div>
                <button type="submit" class="btn btn-blood w-100 py-2 fw-bold">ĐĂNG NHẬP</button>
            </form>
            
            <div class="text-center mt-4">
                <small class="text-muted">&copy; 2026 Blood Connect System</small>
            </div>
        </div>
    </div>
</body>
</html>