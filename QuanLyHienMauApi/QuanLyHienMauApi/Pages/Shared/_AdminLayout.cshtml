<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - BloodConnect</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css">
    </head>
    <body>
        <nav id="sidebar">
            <div class="sidebar-header">
                <div class="logo-box">BC</div>
                <span class="fw-bold fs-5 text-dark">BloodConnect</span>
            </div>
            <div class="mt-4">
                <a href="/Admin/Index" class="nav-link @(ViewContext.RouteData.Values["page"].ToString().Contains("Index") ? "active" : "")">
                    <i class="fa-solid fa-chart-pie"></i> Trang chủ
                </a>
                <a href="/Admin/DuyetCoSo" class="nav-link @(ViewContext.RouteData.Values["page"].ToString().Contains("DuyetCoSo") ? "active" : "")">
                    <i class="fa-solid fa-hospital"></i> Quản lý Cơ sở y tế
                </a>
                <a href="/Admin/QuanLyBanTin" class="nav-link @(ViewContext.RouteData.Values["page"].ToString().Contains("QuanLyBanTin") ? "active" : "")">
                    <i class="fa-solid fa-newspaper"></i> Quản lý bản tin
                </a>
                <a href="/Admin/DuyetNhomMau" class="nav-link @(ViewContext.RouteData.Values["page"].ToString().Contains("DuyetNhomMau") ? "active" : "")">
                    <i class="fa-solid fa-check-to-slot"></i> Xác nhận nhóm máu
                </a>
                <a href="/Admin/QuanLyBaoCao" class="nav-link @(ViewContext.RouteData.Values["page"].ToString().Contains("QuanLyBaoCao") ? "active" : "")">
                    <i class="fa-solid fa-triangle-exclamation"></i> Quản lý báo cáo
                </a>
                <a href="/Admin/QuanLyTaiKhoan" class="nav-link @(ViewContext.RouteData.Values["page"].ToString().Contains("QuanLyTaiKhoan") ? "active" : "")">
                    <i class="fa-solid fa-users"></i> Quản lý tài khoản
                </a>
            </div>
        </nav>

        <div id="content">
            <header class="top-header">
                <div class="header-icon">
                    <i class="fa-regular fa-bell"></i>
                </div>
                <a href="/Admin/Login" class="logout-btn">
                    <i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất
                </a>
            </header>

            <div class="p-4">
                @RenderBody()
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>